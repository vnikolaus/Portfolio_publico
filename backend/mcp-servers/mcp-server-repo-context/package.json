{
  "name": "mcp-server-repo-context",
  "version": "0.1.0",
  "description": "Servidor MCP simples para documentacao inteligente de projetos de software.",
  "type": "module",
  "private": true,
  "main": "dist/server/index.js",
  "scripts": {
    "postinstall": "mcp-use generate-types --server src/server/index.ts || exit 0",
    "dev": "mcp-use dev --entry src/server/index.ts",
    "build": "mcp-use build --entry src/server/index.ts --no-typecheck",
    "start": "mcp-use start --entry src/server/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.2.0",
    "ignore": "^6.0.2",
    "mcp-use": "^1.3.8",
    "simple-git": "^3.27.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
